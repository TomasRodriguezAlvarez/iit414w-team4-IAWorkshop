   "source": [
    "# Permutation Importance for Linear Regression\n",
    "from sklearn.inspection import permutation_importance\n",
    "\n",
    "# We evaluate importance on the test set to measure generalization, not memorization.\n",
    "# Scoring uses negative MAE so values can be interpreted as MAE increase when a feature is shuffled.\n",
    "perm_result = permutation_importance(\n",
    "    estimator=lr,\n",
    "    X=X_test,\n",
    "    y=y_test,\n",
    "    n_repeats=30,\n",
    "    random_state=RANDOM_SEED,\n",
    "    scoring=\"neg_mean_absolute_error\"\n",
    " )\n",
    "\n",
    "# Build a readable table with mean importance and variability across shuffles.\n",
    "perm_df = pd.DataFrame({\n",
    "    \"feature\": X_test.columns,\n",
    "    \"mae_increase_mean\": perm_result.importances_mean,\n",
    "    \"mae_increase_std\": perm_result.importances_std\n",
    "}).sort_values(\"mae_increase_mean\", ascending=False).reset_index(drop=True)\n",
    "\n",
    "print(\"Permutation importance (Linear Regression, test set):\")\n",
    "print(perm_df.to_string(index=False))\n",
    "\n",
    "# Interpretation guide:\n",
    "# - Larger mae_increase_mean => feature is more important.\n",
    "# - Values near 0 => feature contributes little incremental signal.\n",
    "# - Negative values can appear from noise/variance and usually indicate low importance.\n",
    "perm_df"
   ]
  },
